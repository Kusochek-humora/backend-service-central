{
  "name": "backend-service-central",
  "version": "1.0.0",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec \"ts-node --project tsconfig.json\" src/server.ts",
    "build": "tsc",
    "migration:generate": "ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:generate -d src/db/data-source.ts",
    "migration:run": "ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:run -d src/db/data-source.ts",
    "migration:revert": "ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:revert -d src/db/data-source.ts",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/db/data-source.js",
    "seed:chief": "ts-node --project tsconfig.json src/db/seeds/create-chief-editor.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "node-cron": "^4.6.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.31.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^6.0.3"
  }
}
